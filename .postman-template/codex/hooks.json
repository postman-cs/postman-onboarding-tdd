{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|Shell|exec_command|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.postman-template/hooks/codex-pre-tool-use.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking Postman TDD agent policy"
          }
        ]
      }
    ]
  }
}
